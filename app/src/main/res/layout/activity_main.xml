<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖"
            android:textSize="60sp"
            android:layout_marginTop="30dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hoshiyar Assistant"
            android:textSize="26sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/tv_default_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checking..."
            android:textSize="13sp"
            android:textColor="#FF9800"
            android:gravity="center"
            android:padding="10dp"
            android:layout_marginTop="15dp" />

        <TextView
            android:id="@+id/tv_command_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kul Commands: 0"
            android:textSize="13sp"
            android:textColor="#4CAF50"
            android:layout_marginBottom="20dp" />

        <Button
            android:id="@+id/btn_open_assistant"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="🎤  Assistant Kholen"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#6C63FF"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btn_floating_ball"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="🤖  Floating Ball On Karen"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#E91E63"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btn_accessibility"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="⚡  Automation On Karen"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF5722"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btn_set_default"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="🏠  Default Assistant Set Karen"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2196F3"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btn_manage_commands"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="📝  Commands Manage Karen"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#009688"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/btn_settings"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="⚙️  Settings"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#455A64"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0D1117"
            android:padding="15dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒 100% Encrypted + Private"
                android:textColor="#4CAF50"
                android:textSize="14sp"
                android:layout_marginBottom="5dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Floating Ball - Har screen par"
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginBottom="3dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Multi-step commands: open youtube > search coding"
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginBottom="3dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✅ Scroll, Click, Type automation"
                android:textColor="#888888"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
